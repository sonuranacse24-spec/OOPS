interface Bank {
    double getInterestRate();
}

class SBI implements Bank {
    @Override
    public double getInterestRate() {
        return 7.1;
    }
}

class HDFC implements Bank {
    @Override
    public double getInterestRate() {
        return 7.9;
    }
}

class ICICI implements Bank {
    @Override
    public double getInterestRate() {
        return 7.5;
    }
}

public class Main {
    public static void main(String[] args) {
        Bank[] banks = {new SBI(), new HDFC(), new ICICI()};
        
        for (Bank b : banks) {
            if (b instanceof SBI)    System.out.print("SBI    : ");
            else if (b instanceof HDFC) System.out.print("HDFC   : ");
            else if (b instanceof ICICI) System.out.print("ICICI  : ");
            
            System.out.println(b.getInterestRate() + "% p.a.");
        }
    }
}
