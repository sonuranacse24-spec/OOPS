class Rectangle {
    float length;
    float breadth;
    
    Rectangle(float l, float b) {
        this.length = l;
        this.breadth = b;
    }
    
    float Area() {
        return length * breadth;
    }
}

public class Main {
    public static void main(String[] args) {
        Rectangle r1 = new Rectangle(4.5f, 5);
        Rectangle r2 = new Rectangle(5, 8);
        
        System.out.println("Area of first rectangle  (4.5 × 5)  = " + r1.Area());
        System.out.println("Area of second rectangle (5 × 8)   = " + r2.Area());
    }
}
